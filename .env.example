# Copy this file to .env and fill in real values. Never commit .env itself.

# ---------- Google Sign-In ----------
# Google Cloud Console -> APIs & Services -> Credentials -> Create Credentials
# -> OAuth client ID -> Web application.
#  - Authorized JavaScript origins: add the origin you'll test/serve from
#    (e.g. http://localhost:3000, and your real domain once deployed).
#  - No redirect URI needs registering — the popup flow used here exchanges
#    its code via Google's "postmessage" mode instead of a real redirect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Apple Sign In ----------
# Requires a paid Apple Developer Program membership (developer.apple.com).
#  1. Certificates, Identifiers & Profiles -> Identifiers -> "+" -> Services
#     IDs -> create one, e.g. "com.puremacros.web" (this is APPLE_CLIENT_ID).
#  2. Configure it for "Sign In with Apple" and add your real HTTPS domain +
#     return URL. Apple does NOT accept plain http://localhost here — use a
#     tunnel (ngrok) or a real deployed domain while testing.
# Only the Services ID is needed below: the backend verifies the identity
# token Apple's JS SDK returns directly against Apple's public keys, which is
# Apple's documented way to authenticate a sign-in (no client secret needed
# for that — a client secret is only required for optional server-to-server
# calls like refreshing/revoking tokens, which this app doesn't use).
APPLE_CLIENT_ID=

# ---------- Postgres (Supabase) ----------
# Supabase dashboard -> Project Settings -> Database -> Connection string.
# Use the "Session pooler" URI (port 5432, host like
# aws-0-<region>.pooler.supabase.com, username postgres.<project-ref>) rather
# than the direct connection — Supabase's direct connection is IPv6-only by
# default and most hosts (including Render) don't have IPv6 egress, so the
# direct URI will just hang/time out there. Session mode is IPv4-compatible
# and behaves like a normal long-lived Postgres connection, which is what
# this app's `pg` Pool expects (the Transaction pooler on 6543 multiplexes
# connections in a way that breaks prepared statements `pg` uses by default).
# Run `server/db/schema.sql` against this database once before first boot.
DATABASE_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ---------- Cloudinary ----------
# cloudinary.com -> free account -> Dashboard for cloud name + API key/secret.
# CLOUDINARY_API_KEY/SECRET are used server-side only (uploading a base64
# fallback photo, e.g. the migration script).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Settings -> Upload -> Upload presets -> "Add upload preset" -> Signing
# Mode: Unsigned. This name is sent to the browser (GET /api/media/config)
# so the client can upload weight/scan photos directly to Cloudinary — an
# unsigned preset only grants "create a new asset", never read/list/delete,
# so it's safe to expose.
CLOUDINARY_UPLOAD_PRESET=
